#!/bin/sh
# Bump builder patch version and re-stage oh-version.js (requires Node on PATH).
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 0
if ! command -v node >/dev/null 2>&1; then
  echo "OHCredits: node not found — skipping version bump (install Node or run: node tools/bump-version.mjs)"
  exit 0
fi
node tools/bump-version.mjs
